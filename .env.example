# ─────────────────────────────────────────────────────────
# OFFLORA — Environment Variables
# Copy this file to .env.local for development
# Set all of these in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ── REQUIRED ────────────────
# Get from: https://console.neon.tech → Your Project → Connection Details → Prisma
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/offlora?sslmode=require"

# ── JWT Secret ── REQUIRED ────────────────────────────────
# Generate with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
JWT_SECRET="paste-your-generated-random-string-here"

# ── Site URL ── REQUIRED ──────────────────────────────────
# Local dev:           http://localhost:3000
# Vercel preview:      https://offlora.vercel.app
# Production domain:   https://offlora.in
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Gmail SMTP (Contact Form) ── REQUIRED for contact form ─
#
# STEP-BY-STEP SETUP:
#
# 1. Use your Gmail address below (e.g. yourname@gmail.com)
GMAIL_USER="yourname@gmail.com"
#
# 2. GMAIL_APP_PASSWORD is NOT your normal Gmail password.
#    You must generate a 16-character App Password:
#
#    a. Go to your Google Account → https://myaccount.google.com
#    b. Click "Security" in the left sidebar
#    c. Under "How you sign in to Google" → enable 2-Step Verification
#       (required before App Passwords work)
#    d. After enabling 2FA, go back to Security
#    e. Search for "App passwords" in the search bar at the top
#       OR go to: https://myaccount.google.com/apppasswords
#    f. Click "Create app password"
#    g. In the app name field type: Offlora
#    h. Click "Create" — Google shows a 16-character password like: abcd efgh ijkl mnop
#    i. Copy it WITHOUT the spaces: abcdefghijklmnop
#    j. Paste it below:
#
GMAIL_APP_PASSWORD="abcdefghijklmnop"
#
# 3. This is the email address where contact form messages are delivered.
#    Can be same as GMAIL_USER or a different address (e.g. your work email).
CONTACT_RECEIVER_EMAIL="yourname@gmail.com"

# ── Image Storage ─────────────────────────────────────────
# No external service needed.
# Images are stored directly in Neon PostgreSQL as base64.
# Served via /api/images/[id] — zero cost, zero setup.
